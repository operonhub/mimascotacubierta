---
import HeaderLink from './HeaderLink.astro';
---

<header>
  <nav>
    <a href="/" class="logo-link">
      <img src="/logpng1.png" alt="MiMascotaCubierta logo" class="logo-img" height="40" width="auto" />
      <span class="logo-text">MiMascotaCubierta<span class="logo-tld">.com</span></span>
    </a>

    <button class="hamburger" aria-label="Abrir menú" aria-expanded="false" aria-controls="nav-menu">
      <svg width="22" height="22" viewBox="0 0 22 22" fill="none" aria-hidden="true">
        <rect y="3"  width="22" height="2" rx="1" fill="currentColor"/>
        <rect y="10" width="22" height="2" rx="1" fill="currentColor"/>
        <rect y="17" width="22" height="2" rx="1" fill="currentColor"/>
      </svg>
    </button>

    <ul class="nav-menu" id="nav-menu" role="list">
      <li><HeaderLink href="/comparar">Comparar</HeaderLink></li>
      <li><HeaderLink href="/seguros-mascotas">Seguros</HeaderLink></li>
      <li><HeaderLink href="/gastos-veterinarios">Gastos Vet.</HeaderLink></li>
      <li><HeaderLink href="/salud-enfermedades">Salud</HeaderLink></li>
      <li><HeaderLink href="/razas">Razas</HeaderLink></li>
      <li><HeaderLink href="/urgencias">Urgencias</HeaderLink></li>
      <li><HeaderLink href="/nutricion-cuidados">Nutrición</HeaderLink></li>
    </ul>
  </nav>
</header>

<script>
  const btn = document.querySelector('.hamburger') as HTMLButtonElement;
  const menu = document.getElementById('nav-menu') as HTMLUListElement;
  btn?.addEventListener('click', () => {
    const open = menu.classList.toggle('is-open');
    btn.setAttribute('aria-expanded', String(open));
  });
  document.addEventListener('click', (e) => {
    if (!btn?.contains(e.target as Node) && !menu?.contains(e.target as Node)) {
      menu?.classList.remove('is-open');
      btn?.setAttribute('aria-expanded', 'false');
    }
  });
</script>

<style>
  header {
    position: fixed;
    inset-block-start: 0;
    inset-inline: 0;
    z-index: 1000;
    height: 64px;
    background: #0f4c35;
    box-shadow: 0 2px 12px rgba(0,0,0,0.25);
  }
  nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 100%;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
    gap: 1.5rem;
  }

  /* Logo */
  .logo-link {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    text-decoration: none;
    flex-shrink: 0;
  }
  .logo-img {
    height: 40px;
    width: auto;
    object-fit: contain;
  }
  .logo-text {
    font-size: 1rem;
    font-weight: 800;
    color: #ffffff;
    white-space: nowrap;
    letter-spacing: -0.02em;
  }
  .logo-tld { color: #6efac1; }

  /* Nav links */
  .nav-menu {
    display: flex;
    list-style: none;
    gap: 0.1rem;
    margin: 0;
    padding: 0;
  }
  .nav-menu :global(a) {
    display: block;
    padding: 0.45rem 0.7rem;
    color: rgba(255,255,255,0.82);
    font-size: 0.875rem;
    font-weight: 500;
    border-bottom: 2px solid transparent;
    text-decoration: none;
    white-space: nowrap;
    transition: color 0.15s, border-color 0.15s;
  }
  .nav-menu :global(a:hover),
  .nav-menu :global(a.active) {
    color: #ffffff;
    border-bottom-color: #6efac1;
    text-decoration: none;
  }

  /* Hamburger */
  .hamburger {
    display: none;
    background: none;
    border: none;
    color: #ffffff;
    cursor: pointer;
    padding: 6px;
    border-radius: 4px;
    transition: background 0.15s;
  }
  .hamburger:hover { background: rgba(255,255,255,0.1); }

  @media (max-width: 900px) {
    .hamburger { display: flex; align-items: center; }

    .nav-menu {
      display: none;
      flex-direction: column;
      gap: 0;
      position: fixed;
      top: 64px;
      left: 0;
      right: 0;
      background: #0c3e2b;
      padding: 0.75rem 0 1.25rem;
      border-top: 1px solid #1a7d53;
      box-shadow: 0 8px 32px rgba(0,0,0,0.3);
    }
    .nav-menu.is-open { display: flex; }
    .nav-menu :global(a) {
      padding: 0.75rem 1.5rem;
      font-size: 1rem;
      border-bottom: 1px solid rgba(255,255,255,0.06);
      border-left: none;
    }
    .nav-menu :global(a:hover),
    .nav-menu :global(a.active) {
      border-bottom: 1px solid rgba(255,255,255,0.06);
      background: rgba(110,250,193,0.08);
      color: #6efac1;
    }
  }
</style>
