<footer>
  <div class="footer-inner">
    <div class="footer-brand">
      <a href="/" class="footer-logo-link">
        <img src="/logpng1.png" alt="MiMascotaCubierta" height="36" onerror="this.style.display='none'" />
        <span class="footer-logo-text">MiMascotaCubierta<span class="footer-tld">.com</span></span>
      </a>
      <p class="footer-tagline">Seguros y salud para mascotas</p>
      <p class="footer-copy">© 2026 MiMascotaCubierta.com · <a href="https://operon.com.ar">Operon</a></p>
    </div>
    <div class="footer-col">
      <h4>Categorías</h4>
      <ul>
        <li><a href="/comparar">Comparar seguros</a></li>
        <li><a href="/seguros-mascotas">Seguros de mascotas</a></li>
        <li><a href="/gastos-veterinarios">Gastos veterinarios</a></li>
        <li><a href="/salud-enfermedades">Salud y enfermedades</a></li>
        <li><a href="/razas">Razas</a></li>
        <li><a href="/urgencias">Urgencias</a></li>
        <li><a href="/nutricion-cuidados">Nutrición y cuidados</a></li>
        <li><a href="/viajes-mascotas">Viajes con mascotas</a></li>
      </ul>
    </div>
    <div class="footer-col">
      <h4>Legal</h4>
      <ul>
        <li><a href="/sobre-nosotros">Sobre nosotros</a></li>
        <li><a href="/contacto">Contacto</a></li>
        <li><a href="/privacidad">Privacidad</a></li>
        <li><a href="/aviso-legal">Aviso legal</a></li>
        <li><a href="/cookies">Cookies</a></li>
      </ul>
    </div>
  </div>
</footer>

<style>
footer {
  background: #0f4c35;
  border-top: 3px solid #1a7d53;
  padding: 3.5rem 0 2rem;
  color: rgba(255,255,255,0.75);
}
.footer-inner {
  max-width: 1200px;
  margin: 0 auto;
  padding: 0 1.5rem;
  display: grid;
  grid-template-columns: 2fr 1fr 1fr;
  gap: 3rem;
}
.footer-logo-link {
  display: flex;
  align-items: center;
  gap: 0.55rem;
  text-decoration: none;
  margin-bottom: 0.75rem;
}
.footer-logo-link img { height: 36px; width: auto; }
.footer-logo-text {
  font-size: 1rem;
  font-weight: 800;
  color: #ffffff;
  white-space: nowrap;
}
.footer-tld { color: #6efac1; }
.footer-tagline {
  font-size: 0.88rem;
  color: rgba(255,255,255,0.6);
  margin-bottom: 1.25rem;
}
.footer-copy {
  font-size: 0.82rem;
  color: rgba(255,255,255,0.4);
}
.footer-copy a {
  color: rgba(255,255,255,0.5);
  text-decoration: none;
}
.footer-copy a:hover { color: #6efac1; }
.footer-col h4 {
  font-size: 0.78rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  color: rgba(255,255,255,0.45);
  margin-bottom: 1rem;
}
.footer-col ul {
  list-style: none;
  padding: 0;
  margin: 0;
  display: flex;
  flex-direction: column;
  gap: 0.55rem;
}
.footer-col a {
  font-size: 0.88rem;
  color: rgba(255,255,255,0.7);
  text-decoration: none;
  transition: color 0.15s;
}
.footer-col a:hover { color: #6efac1; text-decoration: none; }
@media (max-width: 768px) {
  .footer-inner {
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
  }
  .footer-brand { grid-column: 1 / -1; }
}
@media (max-width: 480px) {
  .footer-inner { grid-template-columns: 1fr; }
}
</style>
