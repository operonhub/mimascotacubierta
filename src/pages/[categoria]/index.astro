---
import Layout from '../../layouts/Layout.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import { categorias } from '../../data/categorias';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  // `razas` tiene su propia página estática (con subcategorías perros/gatos),
  // así que se excluye acá para evitar una colisión de rutas en /razas/.
  return categorias
    .filter((cat) => cat.slug !== 'razas')
    .map((cat) => ({
      params: { categoria: cat.slug },
      props: { cat },
    }));
}

const { cat } = Astro.props;

// Artículos de esta categoría (sin borradores), más nuevos primero
const allArticles = await getCollection(
  'blog',
  ({ data }) => !data.draft && data.categorySlug === cat.slug,
);
const articles = allArticles.sort(
  (a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime(),
);

// El CTA de comparador solo se muestra en estas categorías
const showCta = ['seguros-mascotas', 'gastos-veterinarios', 'urgencias'].includes(
  cat.slug,
);
---

<Layout
  title={`${cat.nombre} — Guías y comparativas | MiMascotaCubierta.com`}
  description={cat.descripcion}
>
  <!-- ─── A) HERO ─────────────────────────────────────── -->
  <section class="cat-hero" style={`background:${cat.color}`}>
    <div class="container">
      <span class="cat-emoji" aria-hidden="true">{cat.emoji}</span>
      <h1>{cat.nombre}</h1>
      <p class="cat-desc">{cat.descripcion}</p>
      <div class="cat-stats">
        {cat.stats.map((s) => (
          <div class="stat-box">
            <span class="stat-valor">{s.valor}</span>
            <span class="stat-label">{s.label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ─── B) INTRO ────────────────────────────────────── -->
  <section class="cat-intro">
    <div class="container container-narrow">
      <nav class="breadcrumb" aria-label="Migas de pan">
        <a href="/">Home</a>
        <span class="sep" aria-hidden="true">›</span>
        <span class="crumb-current">{cat.nombre}</span>
      </nav>
      <p class="intro-text">{cat.intro}</p>
    </div>
  </section>

  <!-- ─── C) ARTÍCULOS ────────────────────────────────── -->
  <section class="cat-articles">
    <div class="container">
      {articles.length > 0 ? (
        <div class="art-grid">
          {articles.map((article) => (
            <ArticleCard
              title={article.data.title}
              category={article.data.category}
              pubDate={article.data.pubDate}
              href={`/${article.id}/`}
              image={article.data.image}
              imageAlt={article.data.imageAlt}
            />
          ))}
        </div>
      ) : (
        <div class="empty-state">
          <span class="empty-emoji" aria-hidden="true">{cat.emoji}</span>
          <h2>Próximamente</h2>
          <p>Estamos trabajando en los artículos de esta categoría.</p>
        </div>
      )}
    </div>
  </section>

  <!-- ─── D) CTA COMPARADOR ───────────────────────────── -->
  {showCta && (
    <section class="cat-cta">
      <div class="container">
        <div class="cta-card">
          <h2>¿Querés proteger a tu mascota?</h2>
          <p>Comparamos todos los seguros disponibles en Argentina y México.</p>
          <a class="cta-btn" href="/comparar">Comparar seguros ahora →</a>
        </div>
      </div>
    </section>
  )}
</Layout>

<style>
  .container { max-width: 1200px; margin: 0 auto; padding: 0 1.5rem; }
  .container-narrow { max-width: 800px; }

  /* ── A) Hero ─────────────────────────────── */
  .cat-hero {
    color: #fff;
    padding: 3rem 0;
    text-align: center;
  }
  .cat-emoji {
    font-size: 64px;
    line-height: 1;
    display: block;
    margin-bottom: 1rem;
  }
  .cat-hero h1 {
    color: #fff;
    font-size: clamp(1.9rem, 5vw, 3rem);
    margin-bottom: 0.85rem;
  }
  .cat-desc {
    color: rgba(255, 255, 255, 0.9);
    font-size: 1.15rem;
    line-height: 1.6;
    max-width: 720px;
    margin: 0 auto 2rem;
  }
  .cat-stats {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 1rem;
  }
  .stat-box {
    background: rgba(255, 255, 255, 0.12);
    border: 1px solid rgba(255, 255, 255, 0.18);
    border-radius: 12px;
    padding: 1rem 1.5rem;
    min-width: 130px;
  }
  .stat-valor {
    display: block;
    font-size: 1.6rem;
    font-weight: 800;
    line-height: 1.1;
  }
  .stat-label {
    display: block;
    font-size: 0.82rem;
    color: rgba(255, 255, 255, 0.8);
    margin-top: 0.25rem;
  }

  /* ── B) Intro ────────────────────────────── */
  .cat-intro { padding: 2.5rem 0 0; background: #fff; }
  .breadcrumb {
    font-size: 0.82rem;
    color: #94a3b8;
    margin-bottom: 1.25rem;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.4rem;
  }
  .breadcrumb a { color: #64748b; text-decoration: none; }
  .breadcrumb a:hover { color: #1a7d53; text-decoration: underline; }
  .breadcrumb .sep { color: #cbd5e1; }
  .crumb-current { color: #94a3b8; }
  .intro-text {
    color: #374151;
    font-size: 1.02rem;
    line-height: 1.85;
  }

  /* ── C) Artículos ────────────────────────── */
  .cat-articles { padding: 3rem 0; background: #fff; }
  .art-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.5rem;
  }

  /* Empty state */
  .empty-state {
    text-align: center;
    padding: 3.5rem 1.5rem;
    border: 1px dashed #cbd5e1;
    border-radius: 12px;
    background: #f8fafc;
  }
  .empty-emoji { font-size: 3.5rem; display: block; margin-bottom: 0.75rem; line-height: 1; }
  .empty-state h2 { font-size: 1.3rem; color: #0f4c35; margin-bottom: 0.4rem; }
  .empty-state p { color: #64748b; max-width: 420px; margin: 0 auto; }

  /* ── D) CTA ──────────────────────────────── */
  .cat-cta { padding: 0 0 4rem; background: #fff; }
  .cta-card {
    background: #0f4c35;
    border-radius: 12px;
    padding: 2.5rem 2rem;
    text-align: center;
    color: #fff;
  }
  .cta-card h2 { color: #fff; font-size: 1.5rem; margin-bottom: 0.6rem; }
  .cta-card p {
    color: rgba(255, 255, 255, 0.85);
    margin-bottom: 1.5rem;
    font-size: 1rem;
  }
  .cta-btn {
    display: inline-block;
    background: #6efac1;
    color: #0f4c35;
    font-weight: 700;
    padding: 0.85rem 1.6rem;
    border-radius: 8px;
    text-decoration: none;
    transition: opacity 0.15s, transform 0.15s;
  }
  .cta-btn:hover { opacity: 0.9; transform: translateY(-2px); text-decoration: none; }

  @media (max-width: 768px) {
    .cat-hero { padding: 2.5rem 0; }
    .cat-articles { padding: 2.5rem 0; }
  }
</style>
