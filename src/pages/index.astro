---
import Layout from '../layouts/Layout.astro';
import Comparador from '../components/Comparador.astro';
import ArticleCard from '../components/ArticleCard.astro';
import { getCollection } from 'astro:content';

// Últimas 3 guías publicadas (más nuevas primero). Si todavía no hay
// artículos, `sorted` queda vacío y mostramos las tarjetas de ejemplo.
const recentArticles = await getCollection('blog', ({ data }) => !data.draft);
const sorted = recentArticles
  .sort(
    (a, b) =>
      new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime(),
  )
  .slice(0, 3);
---

<Layout
  title="Comparar seguros para perros y gatos | MiMascotaCubierta"
  description="Compara seguros de mascotas en México y Argentina. Información real, precios actualizados y guías completas para cuidar a tu perro o gato."
>

  <!-- ─── HERO ───────────────────────────────────────────────── -->
  <section class="hero">
    <div class="hero-inner">
      <div class="hero-text">
        <h1>Encontrá el mejor seguro para tu perro o gato.</h1>
        <p>
          Comparamos los seguros de mascotas disponibles en México y Argentina
          para que elijas con información real, sin letra chica.
        </p>
        <div class="hero-btns">
          <a href="/comparar" class="btn btn-primary">Comparar seguros ahora</a>
          <a href="/gastos-veterinarios" class="btn btn-ghost">Ver guías gratuitas</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── COMPARADOR ────────────────────────────────────────── -->
  <section class="comparador">
    <div class="container">
      <div class="section-header">
        <h2>Los mejores seguros de mascotas</h2>
        <p class="section-sub">Comparamos precios y coberturas reales en Argentina y México</p>
      </div>
      <Comparador mode="preview" />
      <div class="section-cta">
        <a href="/comparar" class="btn btn-outline">Ver comparativa completa →</a>
      </div>
    </div>
  </section>

  <!-- ─── CATEGORÍAS ───────────────────────────────────────── -->
  <section class="categorias">
    <div class="container">
      <div class="section-header">
        <h2>Todo lo que necesitás saber sobre tu mascota</h2>
      </div>
      <div class="cat-grid">
        <a href="/seguros-mascotas" class="cat-card">
          <span class="cat-icon" aria-hidden="true">🛡️</span>
          <h3>Seguros de mascotas</h3>
          <p>Comparativas, reviews y guías de contratación</p>
        </a>
        <a href="/gastos-veterinarios" class="cat-card">
          <span class="cat-icon" aria-hidden="true">💰</span>
          <h3>Gastos veterinarios</h3>
          <p>Precios reales de consultas, cirugías y tratamientos</p>
        </a>
        <a href="/salud-enfermedades" class="cat-card">
          <span class="cat-icon" aria-hidden="true">🏥</span>
          <h3>Salud y enfermedades</h3>
          <p>Enfermedades frecuentes, síntomas y tratamientos</p>
        </a>
        <a href="/razas" class="cat-card">
          <span class="cat-icon" aria-hidden="true">🐾</span>
          <h3>Razas</h3>
          <p>Guías por raza: salud, cuidados y gastos anuales</p>
        </a>
        <a href="/urgencias" class="cat-card">
          <span class="cat-icon" aria-hidden="true">🚨</span>
          <h3>Urgencias</h3>
          <p>Qué hacer ante una emergencia veterinaria</p>
        </a>
        <a href="/nutricion-cuidados" class="cat-card">
          <span class="cat-icon" aria-hidden="true">🥗</span>
          <h3>Nutrición</h3>
          <p>Alimentación, suplementos y cuidados preventivos</p>
        </a>
        <a href="/viajes-mascotas" class="cat-card">
          <span class="cat-icon" aria-hidden="true">✈️</span>
          <h3>Viajes con mascotas</h3>
          <p>Seguros de viaje, documentación y consejos</p>
        </a>
      </div>
    </div>
  </section>

  <!-- ─── POR QUÉ CONFIAR ──────────────────────────────────── -->
  <section class="confianza">
    <div class="container">
      <div class="section-header">
        <h2>¿Por qué confiar en MiMascotaCubierta?</h2>
      </div>
      <div class="trust-grid">
        <div class="trust-item">
          <div class="trust-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
              <polyline points="22 4 12 14.01 9 11.01"/>
            </svg>
          </div>
          <h3>Información verificada</h3>
          <p>Cada dato es revisado por nuestro equipo antes de publicar. Sin contenido generado sin supervisión.</p>
        </div>
        <div class="trust-item">
          <div class="trust-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <polyline points="23 4 23 10 17 10"/>
              <polyline points="1 20 1 14 7 14"/>
              <path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"/>
            </svg>
          </div>
          <h3>Actualizado mensualmente</h3>
          <p>Los precios y coberturas cambian. Monitoreamos cada seguro para mantenerte informado.</p>
        </div>
        <div class="trust-item">
          <div class="trust-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <circle cx="12" cy="12" r="10"/>
              <line x1="12" y1="8" x2="12" y2="12"/>
              <line x1="12" y1="16" x2="12.01" y2="16"/>
            </svg>
          </div>
          <h3>Sin conflictos de interés</h3>
          <p>Mostramos todas las opciones disponibles, no solo las que pagan más comisión.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── GUÍA / CONTENIDO SEO ─────────────────────────────── -->
  <section class="guia-intro">
    <div class="container container-narrow">
      <h2>Cómo elegir un seguro para tu mascota</h2>
      <p>
        Contratar un seguro para tu perro o gato es una de las decisiones más
        inteligentes que podés tomar como dueño responsable. Una cirugía de
        urgencia o el tratamiento de una enfermedad crónica pueden costar cientos
        de miles de pesos de un día para el otro, y un buen plan transforma ese
        gasto imprevisible en una cuota fija y predecible. La clave está en elegir
        la cobertura correcta según la edad, la raza y el estilo de vida de tu
        mascota.
      </p>

      <h3>Mirá la cobertura, no solo el precio</h3>
      <p>
        El plan más barato no siempre es el más conveniente. Antes de contratar,
        revisá qué incluye realmente cada opción: consultas veterinarias,
        urgencias, cirugías, hospitalización, vacunación y responsabilidad civil.
        Dos planes con precios parecidos pueden tener coberturas muy distintas, y
        esa diferencia se nota justo cuando más lo necesitás. Nuestro comparador te
        muestra en una sola pantalla qué cubre cada aseguradora, sin letra chica.
      </p>

      <h3>Contratá cuando tu mascota está sana</h3>
      <p>
        Casi todas las aseguradoras excluyen las enfermedades preexistentes y
        aplican períodos de carencia antes de activar algunas coberturas. Por eso,
        el mejor momento para contratar es cuando tu perro o gato está joven y
        saludable: pagás menos y accedés a la protección completa desde el
        principio. Si tu mascota ya es adulta, igual conviene asegurarla, aunque
        conviene comparar con más cuidado las condiciones de cada póliza.
      </p>

      <h3>Compará antes de decidir</h3>
      <p>
        Relevamos los seguros de mascotas disponibles en Argentina y México con
        precios reales y coberturas verificadas. No trabajamos para ninguna
        aseguradora en particular: mostramos todas las opciones para que elijas con
        información objetiva. Usá el comparador de arriba para ver los planes lado a
        lado y leé nuestras guías si querés entender en profundidad cada cobertura
        antes de dar el paso.
      </p>
    </div>
  </section>

  <!-- ─── ÚLTIMOS ARTÍCULOS ────────────────────────────────── -->
  <section class="articulos">
    <div class="container">
      <div class="section-header">
        <h2>Guías recientes</h2>
      </div>
      <div class="art-grid">
        {sorted.map((article) => (
          <ArticleCard
            title={article.data.title}
            category={article.data.category}
            pubDate={article.data.pubDate}
            href={`/${article.id}/`}
            image={article.data.image}
            imageAlt={article.data.imageAlt}
          />
        ))}
      </div>
      <div class="section-cta">
        <a href="/guias" class="btn btn-outline">Ver todas las guías →</a>
      </div>
    </div>
  </section>

</Layout>

<style>
/* ── Utilidades compartidas ─────────────────────── */
.section-header {
  text-align: center;
  margin-bottom: 3rem;
}
.section-sub {
  color: #64748b;
  font-size: 0.95rem;
  margin-top: 0.4rem;
}
.section-cta {
  text-align: center;
  margin-top: 2.5rem;
}
.container-narrow { max-width: 760px; }

/* ── Guía / contenido SEO ────────────────────────── */
.guia-intro {
  padding: 5rem 0;
  background: #ffffff;
}
.guia-intro h2 {
  color: #0f4c35;
  font-size: clamp(1.5rem, 3vw, 2rem);
  margin-bottom: 1.25rem;
  line-height: 1.2;
}
.guia-intro h3 {
  color: #1a7d53;
  font-size: 1.15rem;
  margin-top: 2rem;
  margin-bottom: 0.6rem;
}
.guia-intro p {
  color: #374151;
  line-height: 1.85;
  font-size: 1.02rem;
  margin-bottom: 1rem;
}

.btn {
  display: inline-block;
  padding: 0.8rem 1.6rem;
  border-radius: 8px;
  font-weight: 700;
  font-size: 0.95rem;
  text-decoration: none;
  transition: opacity 0.15s, transform 0.15s;
  cursor: pointer;
  line-height: 1;
}
.btn:hover { opacity: 0.9; transform: translateY(-2px); text-decoration: none; }
.btn-primary  { background: #6efac1; color: #0f4c35; }
.btn-ghost    { background: transparent; border: 2px solid rgba(255,255,255,0.75); color: #ffffff; }
.btn-ghost:hover { background: rgba(255,255,255,0.08); }
.btn-outline  { background: transparent; border: 2px solid #1a7d53; color: #1a7d53; }
.btn-outline:hover { background: #1a7d53; color: #ffffff; }

/* ── Hero ────────────────────────────────────────── */
.hero {
  height: 85vh;
  min-height: 500px;
  background:
    linear-gradient(to right, rgba(15,76,53,0.72) 0%, rgba(15,76,53,0.45) 55%, rgba(15,76,53,0) 100%),
    url('/hero.jpg') center / cover no-repeat;
  display: flex;
  align-items: center;
}
.hero-inner {
  max-width: 1200px;
  width: 100%;
  margin: 0 auto;
  padding: 0 1.5rem;
}
.hero-text { max-width: 560px; }
.hero-text h1 {
  font-size: clamp(2rem, 5vw, 3.5rem);
  font-weight: 800;
  color: #ffffff;
  line-height: 1.1;
  margin-bottom: 1.25rem;
}
.hero-text p {
  color: rgba(255,255,255,0.88);
  font-size: 1.15rem;
  line-height: 1.65;
  margin-bottom: 2rem;
}
.hero-btns {
  display: flex;
  gap: 1rem;
  flex-wrap: wrap;
}

/* ── Comparador ──────────────────────────────────── */
.comparador {
  padding: 5rem 0;
  background: #ffffff;
}

/* ── Categorías ──────────────────────────────────── */
.categorias {
  padding: 5rem 0;
  background: #f8fafc;
}
.cat-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
  gap: 1.25rem;
}
.cat-card {
  display: block;
  background: #ffffff;
  border: 1px solid #e2e8f0;
  border-top: 3px solid #1a7d53;
  border-radius: 12px;
  padding: 1.75rem 1.5rem;
  text-decoration: none;
  color: inherit;
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}
.cat-card:hover {
  transform: translateY(-4px);
  box-shadow: 0 8px 24px rgba(0,0,0,0.08);
  text-decoration: none;
}
.cat-icon {
  display: block;
  font-size: 2.4rem;
  margin-bottom: 0.75rem;
  line-height: 1;
}
.cat-card h3 {
  font-size: 1.02rem;
  margin-bottom: 0.4rem;
  color: #1a1d23;
}
.cat-card p {
  font-size: 0.86rem;
  color: #64748b;
  margin: 0;
  line-height: 1.5;
}

/* ── Confianza ───────────────────────────────────── */
.confianza {
  padding: 5rem 0;
  background: #ffffff;
}
.trust-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
  gap: 1.5rem;
}
.trust-item {
  text-align: center;
  padding: 2rem 1.75rem;
  border-radius: 12px;
  border: 1px solid #f1f5f9;
}
.trust-icon {
  width: 60px;
  height: 60px;
  background: #f0fdf4;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 1.25rem;
  color: #0f4c35;
}
.trust-item h3 {
  font-size: 1.05rem;
  margin-bottom: 0.6rem;
}
.trust-item p {
  font-size: 0.9rem;
  color: #64748b;
  line-height: 1.65;
  margin: 0;
}

/* ── Artículos ───────────────────────────────────── */
.articulos {
  padding: 5rem 0;
  background: #f8fafc;
}
.art-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  gap: 1.5rem;
}

/* ── Responsive ──────────────────────────────────── */
@media (max-width: 768px) {
  .hero {
    background:
      linear-gradient(to bottom, rgba(15,76,53,0.75) 0%, rgba(15,76,53,0.35) 100%),
      url('/hero.jpg') center / cover no-repeat;
    height: auto;
    min-height: 100svh;
    align-items: flex-end;
    padding-bottom: 3.5rem;
  }
  .hero-text { max-width: 100%; }
  .hero-btns { flex-direction: column; }
  .btn { text-align: center; }
  .comparador,
  .categorias,
  .confianza,
  .guia-intro,
  .articulos { padding: 3.5rem 0; }
  .section-header { margin-bottom: 2rem; }
}

@media (max-width: 480px) {
  .cat-grid { grid-template-columns: 1fr 1fr; }
}
</style>
